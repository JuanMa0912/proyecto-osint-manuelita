# ============================================================
# .gitignore — Proyecto OSINT Manuelita
# ============================================================

# ----- Entorno y credenciales -----
.env
*.env.local
.env.*
!.env.example

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
.eggs/

# ----- PDFs descargados (binarios grandes) -----
# Los PDFs originales no se versionan — se regeneran con el pipeline
data_raw/pdfs/*.pdf

# ----- Datos crudos generados (reproducibles con el pipeline) -----
data_raw/web/*.html
data_raw/web/*.json

# ----- JSONs grandes procesados -----
# Solo excluir los JSONs de texto completo (>100KB)
data_processed/json/pdf_*.json
data_processed/json/normalized_manuelita_pdf_*.json
data_processed/json/normalized_manuelita_youtube_*.json
data_processed/json/youtube_canal_manuelita.json
data_processed/json/normalized_doc_*.json

# MANTENER en el repo:
# data_processed/json/normalized_manuelita_web_*.json  ← perfiles web
# data_processed/json/normalized_manuelita_social_*.json ← redes sociales
# data_processed/json/news_index.json ← índice de noticias

# ----- Logs de ejecución -----
logs/*.log
logs/**/*.log

# ----- Herramientas de Claude Code -----
.claude/

# ----- IDEs y editores -----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----- Archivos temporales -----
demo_output_generator.py
*.tmp
*.bak

# ----- Jupyter -----
.ipynb_checkpoints/
*.ipynb

# ----- Tests y coverage -----
.pytest_cache/
htmlcov/
.coverage
coverage.xml
