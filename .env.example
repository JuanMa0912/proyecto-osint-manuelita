# ============================================================
# .env.example — Proyecto OSINT Manuelita
# Copia este archivo como .env y rellena tus credenciales
# NUNCA subas el archivo .env real a un repositorio
# ============================================================

# ---- Empresa Objetivo ----
TARGET_COMPANY=Manuelita
TARGET_DOMAIN=manuelita.com
TARGET_URL=https://www.manuelita.com

# ---- YouTube Data API v3 ----
# Obtener en: https://console.cloud.google.com/
YOUTUBE_API_KEY=TU_YOUTUBE_API_KEY_AQUI
YOUTUBE_CHANNEL_ID=UCanNTjBY24t7fID3tj0WfTw

# ---- Meta Graph API (opcional) ----
# Obtener en: https://developers.facebook.com/
META_ACCESS_TOKEN=TU_META_TOKEN_AQUI
FACEBOOK_PAGE_ID=ManuelitaAgroindustria

# ---- LinkedIn (opcional - API oficial) ----
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# ---- Configuración de Scraping ----
# Delay en segundos entre requests (mínimo recomendado: 2.0)
SCRAPING_DELAY_MIN=2.0
SCRAPING_DELAY_MAX=4.0

# Máximo de páginas a scrapear por fuente
MAX_PAGES_WEB=50
MAX_PAGES_NEWS=100
MAX_VIDEOS_YOUTUBE=200

# Timeout de requests en segundos
REQUEST_TIMEOUT=15

# Número de reintentos ante fallo
MAX_RETRIES=3

# ---- Paths de Salida ----
DATA_RAW_PATH=./data_raw
DATA_PROCESSED_PATH=./data_processed
LOGS_PATH=./logs

# ---- Logging ----
# Niveles: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_TO_FILE=true

# ---- Configuración de NLP ----
# Modelo de spaCy en español
SPACY_MODEL=es_core_news_lg

# ---- Deduplicación ----
# Umbral de similitud MinHash (0.0 a 1.0)
DEDUP_THRESHOLD=0.85

# ---- App Q&A — Proveedor LLM ----
# Opciones: "ollama" (local) | "gemini" (API gratuita)
LLM_PROVIDER=ollama

# ---- Ollama (local) ----
OLLAMA_MODEL=llama3.2:1b
OLLAMA_NUM_CTX=32768

# ---- Google Gemini (API gratuita) ----
# Obtener API key GRATIS en: https://aistudio.google.com/apikey
# Tier gratuito: 15 req/min, 1 500 req/dia, contexto de 1M tokens
GEMINI_API_KEY=TU_GEMINI_API_KEY_AQUI
GEMINI_MODEL=gemini-1.5-flash
